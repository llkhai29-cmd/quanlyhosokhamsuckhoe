rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Catch-All Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Global helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprint for Checkup Records to block "Dirty Dozen" invalid shapes
    function isValidCheckupRecord(data) {
      return data.keys().hasAll(['id', 'date', 'facility', 'managedArea', 'category', 'quantity', 'createdAt', 'userId'])
        && data.keys().size() <= 10 // id, date, facility, managedArea, category, quantity, notes, createdAt, syncedAt, userId
        && data.id is string && data.id.size() <= 128
        && data.date is string && data.date.size() == 10 && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.facility is string && data.facility.size() > 0 && data.facility.size() <= 200
        && data.managedArea is string && data.managedArea.size() > 0 && data.managedArea.size() <= 200
        && data.category is string && (
          data.category == 'under_6' || 
          data.category == 'from_6_to_18' || 
          data.category == 'from_18_to_60_community' || 
          data.category == 'from_18_to_60_worker' || 
          data.category == 'from_18_to_60_officer' || 
          data.category == 'above_60'
        )
        && data.quantity is int && data.quantity >= 0
        && data.createdAt is int
        && data.userId is string && data.userId.size() <= 128
        && (!data.keys().hasAny(['notes']) || (data.notes is string && data.notes.size() <= 1000))
        && (!data.keys().hasAny(['syncedAt']) || (data.syncedAt is int || data.syncedAt == null));
    }

    // 4. Match and protect /records/{recordId}
    match /records/{recordId} {
      allow get: if isSignedIn() 
        && isValidId(recordId) 
        && existing().userId == request.auth.uid;

      allow list: if isSignedIn() 
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && isValidId(recordId)
        && isValidCheckupRecord(incoming())
        && incoming().userId == request.auth.uid;

      allow delete: if isSignedIn()
        && isValidId(recordId)
        && existing().userId == request.auth.uid;

      allow update: if isSignedIn()
        && isValidId(recordId)
        && isValidCheckupRecord(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().id == existing().id
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['date', 'facility', 'managedArea', 'category', 'quantity', 'notes', 'syncedAt']);
    }

    // 5. Match and protect /targets/{userId}
    match /targets/{userId} {
      allow read, write: if isSignedIn() && userId == request.auth.uid;
    }
  }
}
